# MyBill backend configuration — copy to `.env` and fill in.
# Every variable maps to a field on app.core.config.Settings.

# ---- App ----
APP_NAME="MyBill API"
ENVIRONMENT=development          # development | staging | production | test
DEBUG=true
API_V1_PREFIX=/v1

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Logging ----
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                   # true in staging/production for structured logs

# ---- CORS ----
# JSON array of allowed origins. Use specific origins in production, e.g.:
# CORS_ORIGINS=["https://app.yourdomain.com"]
CORS_ORIGINS=["*"]

# ---- Supabase (added in task 1.1.4 / 1.2.1) ----
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# ---- Redis / Celery (added in Phase 2) ----
# REDIS_URL=redis://localhost:6379/0
