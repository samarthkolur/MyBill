# MyBill backend configuration — copy to `.env` and fill in.
# Every variable maps to a field on app.core.config.Settings.

# ---- App ----
APP_NAME="MyBill API"
ENVIRONMENT=development          # development | staging | production | test
DEBUG=true
API_V1_PREFIX=/v1

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Logging ----
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                   # true in staging/production for structured logs

# ---- CORS ----
# JSON array of allowed origins. Use specific origins in production, e.g.:
# CORS_ORIGINS=["https://app.yourdomain.com"]
CORS_ORIGINS=["*"]

# ---- Supabase ----
# API URL for the supabase-py / supabase_flutter clients — NOT a Postgres URL.
# Format: https://<project-ref>.supabase.co
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_ANON_KEY=            # Project Settings → API → anon/public key
# SUPABASE_SERVICE_ROLE_KEY=   # Project Settings → API → service_role key (server-only!)
# SUPABASE_JWT_SECRET=         # Project Settings → API → JWT Settings (for token verification)
#
# Direct Postgres connection for migrations / SQLAlchemy. On an IPv4-only network the
# direct host (db.<ref>.supabase.co:5432) is unreachable (IPv6-only) — use the Supavisor
# "Session pooler" string from Dashboard → Project Settings → Database → Connection string:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# SUPABASE_DB_URL=

# ---- Redis / Celery (Phase 2 OCR pipeline) ----
# Redis is both the Celery broker and result backend. Under docker compose this is set to
# the compose-managed `redis` service; locally, point it at your own Redis.
REDIS_URL=redis://localhost:6379/0
